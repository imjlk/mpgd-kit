{
  "name": "mpgd-kit",
  "private": true,
  "version": "0.0.0",
  "description": "Multi-Platform Game Distribution / Development kit for Phaser games.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/mpgd-kit.git"
  },
  "bugs": {
    "url": "https://github.com/imjlk/mpgd-kit/issues"
  },
  "homepage": "https://github.com/imjlk/mpgd-kit#readme",
  "keywords": [
    "mpgd",
    "phaser",
    "vite",
    "typescript",
    "capacitor",
    "apps-in-toss",
    "game-development",
    "game-distribution"
  ],
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "i18n:build": "pnpm --dir packages/i18n paraglide:build",
    "check": "pnpm i18n:build && pnpm validate:public && ttsc --noEmit -p tsconfig.tools.json && pnpm validate:starter-workflow && pnpm -r --if-present check",
    "dev:game": "pnpm --dir examples/phaser-starter dev",
    "lint": "pnpm -r --if-present lint",
    "format": "pnpm -r --if-present format",
    "fix": "pnpm -r --if-present fix",
    "test": "pnpm build:packages && pnpm smoke:target-config:dist && pnpm test:workspaces && pnpm smoke:target-config && pnpm smoke:effective-config && pnpm smoke:adapter-effective-config && pnpm smoke:game-services:prepared && pnpm smoke:game-services:worker:prepared",
    "test:workspaces": "pnpm -r --if-present test",
    "validate:catalog": "node tools/run-ttsx.mjs tools/validate-product-catalog.ts",
    "validate:ads": "node tools/run-ttsx.mjs tools/validate-ad-placements.ts",
    "validate:i18n": "pnpm --dir packages/i18n test",
    "validate:target-config": "MPGD_PLATFORM_TARGETS_FILE=${MPGD_PLATFORM_TARGETS_FILE:-examples/phaser-starter/mpgd.targets.json} node tools/run-ttsx.mjs tools/validate-target-config.ts",
    "validate:effective-config": "MPGD_PLATFORM_TARGETS_FILE=${MPGD_PLATFORM_TARGETS_FILE:-examples/phaser-starter/mpgd.targets.json} node tools/run-ttsx.mjs tools/validate-effective-target-config.ts",
    "validate:targets": "MPGD_PLATFORM_TARGETS_FILE=${MPGD_PLATFORM_TARGETS_FILE:-examples/phaser-starter/mpgd.targets.json} node tools/run-ttsx.mjs tools/target/validate-target-config.ts",
    "validate:public": "MPGD_PLATFORM_TARGETS_FILE=${MPGD_PLATFORM_TARGETS_FILE:-examples/phaser-starter/mpgd.targets.json} node tools/run-ttsx.mjs tools/validate-public-readiness.ts",
    "validate:starter-workflow": "node tools/run-ttsx.mjs tools/validate-starter-workflow.ts",
    "mpgd": "node tools/run-ttsx.mjs --mpgd-cli packages/cli/src/bin.ts",
    "create:game": "node tools/run-ttsx.mjs --mpgd-cli packages/cli/src/bin.ts game create",
    "build:target": "pnpm i18n:build && MPGD_PLATFORM_TARGETS_FILE=${MPGD_PLATFORM_TARGETS_FILE:-examples/phaser-starter/mpgd.targets.json} node tools/run-ttsx.mjs tools/target/build-target.ts",
    "build:web": "pnpm build:target web-preview production",
    "build:microsoft-store": "pnpm build:target microsoft-store production",
    "build:android": "pnpm build:target android production",
    "build:ios": "pnpm build:target ios production",
    "build:ait": "pnpm build:target ait production",
    "build:devvit": "pnpm build:target reddit production",
    "build:effective-config": "MPGD_PLATFORM_TARGETS_FILE=${MPGD_PLATFORM_TARGETS_FILE:-examples/phaser-starter/mpgd.targets.json} node tools/run-ttsx.mjs tools/target/generate-effective-target-config.ts",
    "build:packages": "pnpm i18n:build && node tools/run-ttsx.mjs tools/package/build-packages.ts",
    "pack:packages": "pnpm build:packages && pnpm pack:packages:prepared",
    "pack:packages:prepared": "node tools/run-ttsx.mjs tools/package/pack-packages.ts",
    "smoke:target": "MPGD_PLATFORM_TARGETS_FILE=${MPGD_PLATFORM_TARGETS_FILE:-examples/phaser-starter/mpgd.targets.json} node tools/run-ttsx.mjs tools/smoke/verify-target-artifacts.ts",
    "smoke:targets": "MPGD_PLATFORM_TARGETS_FILE=${MPGD_PLATFORM_TARGETS_FILE:-examples/phaser-starter/mpgd.targets.json} node tools/run-ttsx.mjs tools/smoke/verify-target-artifacts.ts",
    "smoke:i18n": "pnpm --dir packages/i18n test",
    "smoke:target-config": "node tools/run-ttsx.mjs tools/smoke/target-config-runtime.ts",
    "smoke:target-config:dist": "node packages/target-config/test/dist-import.mjs",
    "smoke:effective-config": "MPGD_PLATFORM_TARGETS_FILE=${MPGD_PLATFORM_TARGETS_FILE:-examples/phaser-starter/mpgd.targets.json} node tools/run-ttsx.mjs tools/smoke/effective-target-config.ts",
    "smoke:adapter-effective-config": "MPGD_PLATFORM_TARGETS_FILE=${MPGD_PLATFORM_TARGETS_FILE:-examples/phaser-starter/mpgd.targets.json} node tools/run-ttsx.mjs tools/smoke/adapter-effective-config.ts",
    "smoke:game-services": "pnpm build:packages && pnpm smoke:game-services:prepared",
    "smoke:game-services:prepared": "node tools/run-ttsx.mjs tools/smoke/game-services-vertical-slice.ts",
    "smoke:game-services:worker": "pnpm build:packages && pnpm smoke:game-services:worker:prepared",
    "smoke:game-services:worker:prepared": "pnpm --dir apps/game-services-worker check && pnpm --dir apps/game-services-worker build && node tools/run-ttsx.mjs --project apps/game-services-worker/tsconfig.json apps/game-services-worker/src/index.test.ts",
    "smoke:targets:build": "node tools/run-ttsx.mjs tools/smoke/build-target-artifacts.ts",
    "smoke:android:emulator": "node tools/run-ttsx.mjs tools/smoke/android-emulator.ts",
    "smoke:ios:simulator": "node tools/run-ttsx.mjs tools/smoke/ios-simulator.ts",
    "release:target": "node tools/run-ttsx.mjs tools/target/release-target.ts",
    "manifest:release": "node tools/run-ttsx.mjs tools/target/generate-release-manifest.ts",
    "graph:dump": "node tools/graph/inspect-local-graph.mjs --dump",
    "graph:inspect": "node tools/graph/inspect-local-graph.mjs",
    "graph:target": "node tools/graph/inspect-local-graph.mjs --preset target-release",
    "graph:package": "node tools/graph/inspect-local-graph.mjs --preset package-publish",
    "graph:bridge": "node tools/graph/inspect-local-graph.mjs --preset bridge-contracts",
    "graph:starter": "node tools/graph/inspect-local-graph.mjs --preset starter-loop",
    "graph:game-services": "node tools/graph/run-graph-presets.mjs game-services-contract game-services-backend",
    "graph:target-config": "node tools/graph/inspect-local-graph.mjs --preset target-config-runtime",
    "graph:preflight": "node tools/graph/run-graph-presets.mjs",
    "sampo:add": "sampo add",
    "sampo:release:dry-run": "sampo release --dry-run",
    "sampo:release": "sampo release",
    "sampo:publish": "sampo publish",
    "sampo:pre": "sampo pre"
  },
  "devDependencies": {
    "@mpgd/analytics": "workspace:*",
    "@mpgd/adapter-devvit": "workspace:*",
    "@mpgd/backend-ad-reward-ledger": "workspace:*",
    "@mpgd/backend-entitlement-ledger": "workspace:*",
    "@mpgd/backend-leaderboard-ledger": "workspace:*",
    "@mpgd/backend-purchase-verifier": "workspace:*",
    "@mpgd/bridge": "workspace:*",
    "@mpgd/catalog": "workspace:*",
    "@mpgd/game-services": "workspace:*",
    "@mpgd/i18n": "workspace:*",
    "@mpgd/platform": "workspace:*",
    "@mpgd/release-manifest": "workspace:*",
    "@mpgd/target-config": "workspace:*",
    "@ttsc/graph": "0.16.9",
    "@ttsc/lint": "0.16.9",
    "@ttsc/paths": "0.16.9",
    "@ttsc/strip": "0.16.9",
    "@ttsc/unplugin": "0.16.9",
    "@types/node": "^24.0.0",
    "ttsc": "0.16.9",
    "typescript": "rc",
    "typia": "rc",
    "vite": "^8.1.3",
    "vitest": "^4.0.0"
  }
}
