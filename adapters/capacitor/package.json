{
  "name": "@mpgd/adapter-capacitor",
  "version": "0.4.4",
  "description": "Capacitor platform adapter for mpgd Android and iOS shells.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/mpgd-kit.git",
    "directory": "adapters/capacitor"
  },
  "bugs": {
    "url": "https://github.com/imjlk/mpgd-kit/issues"
  },
