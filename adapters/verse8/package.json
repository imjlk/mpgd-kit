  },
  "dependencies": {
    "@mpgd/platform": "workspace:*",
    "@verse8/platform": "2.1.0"
  },
  "devDependencies": {
    "ttsc": "0.18.4",
    "typescript": "7.0.2",
    "vitest": "^4.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
