{
  "name": "@mpgd/adapter-verse8",
  "version": "0.1.0",
  "private": true,
  "description": "Verse8 iframe platform adapter for mpgd games.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/mpgd-kit.git",
    "directory": "adapters/verse8"
  },
  "bugs": {
    "url": "https://github.com/imjlk/mpgd-kit/issues"
  },
  "homepage": "https://github.com/imjlk/mpgd-kit#readme",
  "keywords": [
    "mpgd",
    "phaser",
    "vite",
    "typescript",
    "verse8",
    "game-development",
    "game-distribution"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
