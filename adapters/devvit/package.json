{
  "name": "@mpgd/adapter-devvit",
  "version": "0.8.5",
  "description": "Reddit Devvit Web platform adapter for mpgd games.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/mpgd-kit.git",
    "directory": "adapters/devvit"
  },
  "bugs": {
    "url": "https://github.com/imjlk/mpgd-kit/issues"
  },
  "homepage": "https://github.com/imjlk/mpgd-kit#readme",
  "keywords": [
    "mpgd",
    "phaser",
    "vite",
    "typescript",
    "devvit",
    "reddit",
    "game-development",
    "game-distribution"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./payments": {
      "types": "./dist/payments.d.ts",
      "default": "./dist/payments.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./surface": {
      "types": "./dist/surface.d.ts",
      "default": "./dist/surface.js"
    },
    "./view-mode": {
      "types": "./dist/view-mode.d.ts",
      "default": "./dist/view-mode.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "default": "./dist/web.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "ttsc --noEmit",
    "lint": "ttsc --noEmit",
    "format": "ttsc format",
    "fix": "ttsc fix",
    "test": "vitest run && node test/payments-dist-import.mjs && node test/server-dist-import.mjs && node --conditions=browser test/web-dist-import.mjs"
  },
  "dependencies": {
    "@devvit/web": "0.13.8",
    "@mpgd/bridge": "workspace:*",
    "@mpgd/game-services": "workspace:*",
    "@mpgd/platform": "workspace:*"
  },
  "devDependencies": {
    "ttsc": "0.18.4",
    "typescript": "7.0.2",
    "vitest": "^4.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  }
}
