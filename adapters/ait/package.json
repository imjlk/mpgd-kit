{
  "name": "@mpgd/adapter-ait",
  "version": "0.8.0",
  "description": "Apps in Toss WebView platform adapter for mpgd games.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/mpgd-kit.git",
    "directory": "adapters/ait"
  },
  "bugs": {
    "url": "https://github.com/imjlk/mpgd-kit/issues"
  },
  "homepage": "https://github.com/imjlk/mpgd-kit#readme",
  "keywords": [
    "mpgd",
    "phaser",
    "vite",
    "typescript",
    "capacitor",
    "apps-in-toss",
    "game-development",
    "game-distribution"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./host": {
      "types": "./dist/host.d.ts",
      "default": "./dist/host.js"
    },
    "./wrapper": {
      "types": "./dist/wrapper.d.ts",
      "default": "./dist/wrapper.js"
    },
    "./ad-config": {
      "types": "./dist/ad-config.d.ts",
      "default": "./dist/ad-config.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "ttsc --noEmit",
    "lint": "ttsc --noEmit",
    "format": "ttsc format",
    "fix": "ttsc fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@mpgd/bridge": "workspace:*",
    "@mpgd/platform": "workspace:*"
  },
  "peerDependencies": {
    "@apps-in-toss/web-framework": ">=3.0.0-beta <4"
  },
  "peerDependenciesMeta": {
    "@apps-in-toss/web-framework": {
      "optional": true
    }
  },
  "devDependencies": {
    "@apps-in-toss/web-framework": "3.0.0-beta.da14818",
    "ttsc": "0.18.4",
    "typescript": "7.0.2",
    "vitest": "^4.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  }
}
