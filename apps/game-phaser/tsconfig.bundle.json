{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["vite/client", "node"],
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "vite.config.ts",
    "../../packages/**/*.ts",
    "../../adapters/**/*.ts",
    "../../native-plugins/*/src/**/*.ts"
  ],
  "exclude": [
    "../../adapters/**/dist/**",
    "../../backend/**/dist/**",
    "../../native-plugins/**/dist/**",
    "../../packages/**/dist/**"
  ]
}
