{
  "name": "@mpgd/target-ait",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:plain": "MPGD_AIT_DEVTOOLS=0 VITE_MPGD_AIT_MOCK_IDENTITY=1 vite --host 0.0.0.0",
    "dev:phone": "AIT_TUNNEL=1 AIT_TUNNEL_CDP=1 vite --host 0.0.0.0",
    "build": "vite build",
    "ait:build": "ait build",
    "ait:deploy": "ait deploy --api-key \"$AIT_API_KEY\"",
    "devtools:mcp": "pnpm exec devtools-mcp",
    "devtools:mcp:mobile": "pnpm exec devtools-mcp --target=mobile",
    "test": "pnpm --dir ../../adapters/ait test",
    "check": "ttsc --noEmit",
    "lint": "ttsc --noEmit",
    "format": "ttsc format",
    "fix": "ttsc fix"
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "^2.10.4",
    "@mpgd/adapter-ait": "workspace:*"
  },
  "devDependencies": {
    "@ait-co/devtools": "^0.1.137",
    "@apps-in-toss/cli": "^2.10.4",
    "@ttsc/unplugin": "0.18.4",
    "@types/node": "^24.0.0",
    "ttsc": "0.18.4",
    "typescript": "7.0.2",
    "vite": "^8.1.3"
  }
}
