{
  "name": "@mpgd/target-devvit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare:icon": "pnpm --dir ../.. game:icons:generate -- reddit development",
    "prepare:icon:production": "pnpm --dir ../.. game:icons:generate -- reddit production",
    "dev": "pnpm run prepare:icon && devvit playtest",
    "dev:prepare": "pnpm --dir ../.. build:target reddit staging",
    "dev:client": "APP_TARGET=reddit APP_VERSION=0.0.0-dev BUILD_ID=devvit-watch pnpm --dir ../../examples/phaser-starter exec vite build --mode staging --watch --outDir ../../apps/target-devvit/dist/client",
    "dev:server": "vite build --config vite.server.config.ts --watch",
    "dev:watch": "concurrently --kill-others --success first \"pnpm run dev:client\" \"pnpm run dev:server\"",
    "build": "pnpm --dir ../.. build:target reddit production",
    "build:server": "vite build --config vite.server.config.ts",
    "whoami": "devvit whoami",
    "upload": "pnpm run prepare:icon:production && devvit upload",
    "publish": "pnpm run prepare:icon:production && devvit publish",
    "check": "ttsc --noEmit",
    "lint": "ttsc --noEmit",
    "format": "ttsc format",
    "fix": "ttsc fix"
  },
  "dependencies": {
    "@devvit/web": "0.13.6",
    "@mpgd/adapter-devvit": "workspace:*",
    "@mpgd/bridge": "workspace:*",
    "express": "^5.2.1",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@ttsc/unplugin": "0.16.9",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "concurrently": "10.0.3",
    "devvit": "0.13.6",
    "ttsc": "0.16.9",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.3"
  }
}
