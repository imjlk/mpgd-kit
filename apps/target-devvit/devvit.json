{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "mpgd-kit",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "payments": false,
    "realtime": false
  },
  "scripts": {
    "dev": "pnpm dev:prepare && pnpm build:server -- --watch",
    "build": "pnpm build"
  }
}
