{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "strict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "paths": {
      "@mpgd/bridge/cloudflare-pages": ["./packages/bridge/src/cloudflare-pages.ts"],
      "@mpgd/bridge/orpc": ["./packages/bridge/src/orpc.ts"],
      "@mpgd/bridge/orpc/node": ["./packages/bridge/src/orpc-node.ts"],
      "@mpgd/adapter-devvit/payments": ["./adapters/devvit/src/payments.ts"],
      "@mpgd/adapter-devvit/server": ["./adapters/devvit/src/server/index.ts"],
      "@mpgd/adapter-devvit/surface": ["./adapters/devvit/src/surface.ts"],
      "@mpgd/adapter-devvit/view-mode": ["./adapters/devvit/src/view-mode.ts"],
      "@mpgd/adapter-devvit/web": ["./adapters/devvit/src/web.ts"],
      "@mpgd/adapter-ait/host": ["./adapters/ait/src/host.ts"],
      "@mpgd/adapter-verse8/agent8": ["./adapters/verse8/src/agent8.ts"],
      "@mpgd/adapter-verse8/server": ["./adapters/verse8/src/server.ts"],
      "@mpgd/catalog/*": ["./packages/catalog/*"],
      "@mpgd/game-services/*": ["./packages/game-services/src/*"],
      "@mpgd/platform/*": ["./packages/platform/src/*"],
      "@mpgd/adapter-*": ["./adapters/*/src"],
      "@mpgd/backend-*": ["./backend/*/src"],
      "@mpgd/capacitor-game-services": ["./native-plugins/capacitor-game-services/src"],
      "@mpgd/*": ["./packages/*/src"]
    }
  }
}
