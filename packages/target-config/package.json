{
  "name": "@mpgd/target-config",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./targets.json": "./targets.json"
  },
  "files": [
    "dist",
    "targets.json"
  ],
  "scripts": {
    "check": "ttsc --noEmit",
