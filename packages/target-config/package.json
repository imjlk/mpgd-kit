{
  "name": "@mpgd/target-config",
  "version": "0.5.0",
  "description": "Target-specific platform feature availability and effective config helpers for mpgd.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/mpgd-kit.git",
    "directory": "packages/target-config"
  },
  "bugs": {
    "url": "https://github.com/imjlk/mpgd-kit/issues"
  },
  "homepage": "https://github.com/imjlk/mpgd-kit#readme",
  "keywords": [
    "mpgd",
    "phaser",
    "vite",
    "typescript",
    "capacitor",
    "apps-in-toss",
    "game-development",
    "game-distribution"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./targets.json": "./targets.json"
  },
  "files": [
    "dist",
    "targets.json"
  ],
  "scripts": {
    "check": "ttsc --noEmit",
    "lint": "ttsc --noEmit",
    "format": "ttsc format",
    "fix": "ttsc fix",
    "test": "cd ../.. && node tools/run-ttsx.mjs packages/target-config/test/target-config-smoke.ts"
  },
  "dependencies": {
    "@mpgd/catalog": "workspace:*",
    "@mpgd/platform": "workspace:*",
    "typia": "rc"
  },
  "devDependencies": {
    "ttsc": "0.16.9",
    "typescript": "7.0.1-rc"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  }
}
