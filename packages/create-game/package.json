{
  "name": "@mpgd/create-game",
  "version": "0.5.0",
  "description": "Create a Phaser game starter wired for mpgd-kit targets.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/mpgd-kit.git",
    "directory": "packages/create-game"
  },
  "bugs": {
    "url": "https://github.com/imjlk/mpgd-kit/issues"
  },
  "homepage": "https://github.com/imjlk/mpgd-kit#readme",
  "keywords": [
    "mpgd",
    "phaser",
    "vite",
    "typescript",
    "game-development",
    "game-distribution",
    "create",
    "starter"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "create-game": "./dist/bin.js"
  },
  "scripts": {
    "check": "ttsc --noEmit -p tsconfig.json",
    "lint": "ttsc --noEmit -p tsconfig.json",
    "format": "ttsc format",
    "fix": "ttsc fix"
  },
  "dependencies": {
    "@mpgd/cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "ttsc": "0.16.9",
    "typescript": "7.0.1-rc"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  }
}
