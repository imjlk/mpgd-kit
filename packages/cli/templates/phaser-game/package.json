{
  "name": "__PACKAGE_NAME__",
  "private": true,
  "version": "0.0.0",
  "description": "__GAME_TITLE__ mpgd Phaser game.",
  "type": "module",
  "scripts": {
    "dev": "__WORKSPACE_I18N_BUILD_PREFIX__vite --host 0.0.0.0",
    "build": "__WORKSPACE_I18N_BUILD_PREFIX__vite build",
    "build:microsoft-store": "pnpm exec mpgd target build microsoft-store production --targets-file ./mpgd.targets.json --kit-path ${MPGD_KIT_PATH:-__DEFAULT_KIT_PATH__}",
    "smoke:microsoft-store": "pnpm exec mpgd target smoke microsoft-store --targets-file ./mpgd.targets.json --kit-path ${MPGD_KIT_PATH:-__DEFAULT_KIT_PATH__}",
    "build:devvit": "pnpm exec mpgd target build reddit production --targets-file ./mpgd.targets.json --kit-path ${MPGD_KIT_PATH:-__DEFAULT_KIT_PATH__}",
    "build:devvit:staging": "pnpm exec mpgd target build reddit staging --targets-file ./mpgd.targets.json --kit-path ${MPGD_KIT_PATH:-__DEFAULT_KIT_PATH__}",
    "smoke:devvit": "pnpm exec mpgd target smoke reddit --targets-file ./mpgd.targets.json --kit-path ${MPGD_KIT_PATH:-__DEFAULT_KIT_PATH__}",
    "devvit:init": "pnpm --dir apps/target-devvit run init",
    "devvit:init:copy-paste": "pnpm --dir apps/target-devvit run init:copy-paste",
    "devvit:login": "pnpm --dir apps/target-devvit exec devvit login",
    "devvit:login:copy-paste": "pnpm --dir apps/target-devvit exec devvit login --copy-paste",
    "devvit:whoami": "pnpm --dir apps/target-devvit run whoami",
    "devvit:upload": "pnpm --dir apps/target-devvit run upload",
    "devvit:playtest": "pnpm --dir apps/target-devvit run dev",
    "devvit:publish": "pnpm --dir apps/target-devvit run publish",
    "check": "ttsc --noEmit -p tsconfig.json",
    "lint": "ttsc --noEmit -p tsconfig.json",
    "format": "ttsc format",
    "fix": "ttsc fix"
  },
  "dependencies": {
    "@mpgd/adapter-ait": "__MPGD_DEPENDENCY_VERSION__",
    "@mpgd/adapter-browser": "__MPGD_DEPENDENCY_VERSION__",
    "@mpgd/adapter-capacitor": "__MPGD_DEPENDENCY_VERSION__",
    "@mpgd/adapter-devvit": "__MPGD_DEPENDENCY_VERSION__",
    "@mpgd/analytics": "__MPGD_DEPENDENCY_VERSION__",
    "@mpgd/catalog": "__MPGD_DEPENDENCY_VERSION__",
    "@mpgd/game-services": "__MPGD_DEPENDENCY_VERSION__",
    "@mpgd/i18n": "__MPGD_DEPENDENCY_VERSION__",
    "@mpgd/platform": "__MPGD_DEPENDENCY_VERSION__",
    "@mpgd/phaser-assets": "__MPGD_DEPENDENCY_VERSION__",
    "@mpgd/target-config": "__MPGD_DEPENDENCY_VERSION__",
    "phaser": "4.2.0"
  },
  "devDependencies": {
    "@mpgd/cli": "__MPGD_DEPENDENCY_VERSION__",
    "@ttsc/unplugin": "0.16.9",
    "@types/node": "^24.0.0",
    "ttsc": "0.16.9",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.3"
  }
}
