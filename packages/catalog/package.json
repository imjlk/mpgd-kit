{
  "name": "@mpgd/catalog",
  "version": "0.0.0",
  "description": "Product catalog and ad placement configuration schemas for mpgd games.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/mpgd-kit.git",
    "directory": "packages/catalog"
  },
  "bugs": {
    "url": "https://github.com/imjlk/mpgd-kit/issues"
  },
  "homepage": "https://github.com/imjlk/mpgd-kit#readme",
  "keywords": [
    "mpgd",
    "phaser",
    "vite",
    "typescript",
    "capacitor",
    "apps-in-toss",
    "game-development",
    "game-distribution"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./catalog.json": "./catalog.json",
    "./placements.json": "./placements.json"
  },
  "files": [
    "dist",
    "catalog.json",
    "placements.json"
  ],
  "scripts": {
    "check": "ttsc --noEmit",
    "lint": "ttsc --noEmit",
    "format": "ttsc format",
    "fix": "ttsc fix"
  },
  "dependencies": {
    "@mpgd/platform": "workspace:*",
    "typia": "rc"
  },
  "devDependencies": {
    "ttsc": "0.16.9",
    "typescript": "7.0.1-rc"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  }
}
