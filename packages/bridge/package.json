{
  "name": "@mpgd/bridge",
  "version": "0.3.0",
  "description": "Typed native bridge protocol for mpgd platform adapters.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/mpgd-kit.git",
    "directory": "packages/bridge"
  },
  "bugs": {
    "url": "https://github.com/imjlk/mpgd-kit/issues"
  },
  "homepage": "https://github.com/imjlk/mpgd-kit#readme",
  "keywords": [
    "mpgd",
    "phaser",
    "vite",
    "typescript",
    "capacitor",
    "apps-in-toss",
    "game-development",
    "game-distribution"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./orpc": {
      "types": "./dist/orpc.d.ts",
      "default": "./dist/orpc.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "ttsc --noEmit",
    "lint": "ttsc --noEmit",
    "format": "ttsc format",
    "fix": "ttsc fix",
    "test": "cd ../.. && node tools/run-ttsx.mjs packages/bridge/src/bridge-protocol.test.ts && node tools/run-ttsx.mjs packages/bridge/src/orpc.test.ts"
  },
  "dependencies": {
    "@orpc/client": "2.0.0-beta.14",
    "@orpc/contract": "2.0.0-beta.14",
    "@orpc/server": "2.0.0-beta.14",
    "typia": "rc"
  },
  "devDependencies": {
    "ttsc": "0.16.9",
    "typescript": "7.0.1-rc"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  }
}
