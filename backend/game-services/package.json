{
  "name": "@mpgd/backend-game-services",
  "version": "0.0.0",
  "description": "Authoritative backend implementation, store abstraction, and oRPC handler for mpgd game services.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/mpgd-kit.git",
    "directory": "backend/game-services"
  },
  "bugs": {
    "url": "https://github.com/imjlk/mpgd-kit/issues"
  },
  "homepage": "https://github.com/imjlk/mpgd-kit#readme",
  "keywords": [
    "mpgd",
    "phaser",
    "vite",
    "typescript",
    "capacitor",
    "apps-in-toss",
    "game-development",
    "game-distribution"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "ttsc --noEmit",
    "lint": "ttsc --noEmit",
    "format": "ttsc format",
    "fix": "ttsc fix",
    "test": "cd ../.. && node tools/run-ttsx.mjs backend/game-services/src/index.test.ts"
  },
  "dependencies": {
    "@mpgd/ad-placements": "workspace:*",
    "@mpgd/backend-ad-reward-ledger": "workspace:*",
    "@mpgd/backend-entitlement-ledger": "workspace:*",
    "@mpgd/backend-leaderboard-ledger": "workspace:*",
    "@mpgd/backend-purchase-verifier": "workspace:*",
    "@mpgd/game-services-contract": "workspace:*",
    "@mpgd/game-services-client": "workspace:*",
    "@mpgd/product-catalog": "workspace:*",
    "@orpc/server": "2.0.0-beta.14"
  },
  "devDependencies": {
    "ttsc": "0.16.9",
    "typescript": "7.0.1-rc"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  }
}
