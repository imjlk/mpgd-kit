{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "vite/client"],
    "noEmit": true
  },
  "include": [
    "tools/**/*.ts",
    "packages/**/*.ts",
    "adapters/**/*.ts",
    "backend/**/*.ts",
    "native-plugins/capacitor-game-services/src/**/*.ts",
    "examples/phaser-starter/src/**/*.ts",
    "apps/target-ait/src/**/*.ts",
    "apps/target-devvit/src/**/*.ts",
    "apps/mobile-capacitor/capacitor.config.ts"
  ],
  "exclude": [
    "**/dist/**",
    "packages/cli/templates/**"
  ]
}
